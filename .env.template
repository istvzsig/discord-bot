# Discord Bot Configuration

# Your bot token from Discord Developer Portal
TOKEN=your_bot_token_here

# Application (Client) ID from Discord Developer Portal
CLIENT_ID=your_application_client_id_here

# Your test server (guild) ID for faster command deployment
GUILD_ID=your_guild_id_here

# Discord bot access level
PERMISSION_INT=bot_premission_integer

# Environment mode (optional: development | production)
NODE_ENV=development

# Logging level (debug | info | warn | error)
LOG_LEVEL=info